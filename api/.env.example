# Anti-spam básico (reduz risco, não elimina)
WHATSAPP_MIN_SEND_INTERVAL_MS=90000
WHATSAPP_JITTER_MIN_MS=500
WHATSAPP_JITTER_MAX_MS=2000

# SMTP Email Configuration (Exemplo para Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-do-google
SMTP_SECURE=true
SMTP_FROM="Qbombom" <seu-email@gmail.com>

# Cloudflare R2 Storage (comprovantes de pagamento)
R2_ACCOUNT_ID=seu-account-id
